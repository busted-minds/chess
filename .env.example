# Public browser-safe Supabase credentials
NEXT_PUBLIC_SUPABASE_URL=https://mbqplfqelnljrlvzkmxe.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback supported by the application
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase credential. Never expose this value to the browser.
SUPABASE_SECRET_KEY=
# Legacy fallback supported by the application
SUPABASE_SERVICE_ROLE_KEY=

# Local Supabase CLI only. Never add this value to Vercel.
SUPABASE_DB_PASSWORD=

# Canonical application origin
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional operations integrations (server-only)
CLOUDFLARE_ID=
CLOUDFLARE_API_TOKEN=
# Legacy local name supported by deployment scripts
CLOUDFLARE_TOKEN=
CRON_SECRET=

# Supabase already delivers Auth email through its Resend SMTP integration.
# RESEND_API_KEY is not required by the web application.
